[Unit]
Description=Jazzware Account Intel — FastAPI
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/jazzware-account-intel
EnvironmentFile=/opt/jazzware-account-intel/.env
ExecStart=/opt/jazzware-account-intel/.venv/bin/uvicorn account_intel.api.app:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
